# .env 模板 — 复制为 .env 后填入实际值
# ⚠️ 不要将 .env 提交到 git（已在 .gitignore 中排除）

# GitHub Personal Access Token（repo 权限）
# 生成地址: https://github.com/settings/tokens
ACCESS_TOKEN=

# 仓库地址
REPO_URL=https://github.com/Hawaiine/iptv-sources

# Runner 配置（可按需修改）
RUNNER_NAME=iptv-wuhan
RUNNER_LABELS=self-hosted,iptv,china
RUNNER_GROUP=default

# 是否一次性运行（true = 跑完一个 job 后自动注销）
EPHEMERAL=false